{
  "name": "map-polygon-editor",
  "version": "0.4.0",
  "description": "Data-layer library for map polygon editing with area hierarchies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "map",
    "polygon",
    "editor",
    "geojson",
    "area"
  ],
  "author": "SeijiShii <seiji.shii@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeijiShii/map-polygon-editor.git"
  },
  "homepage": "https://github.com/SeijiShii/map-polygon-editor#readme",
  "dependencies": {
    "@turf/turf": "^7.3.4"
  }
}
